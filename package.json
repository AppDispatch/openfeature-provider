{
  "name": "@appdispatch/openfeature-provider",
  "version": "0.1.0",
  "description": "OpenFeature provider for AppDispatch feature flags",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openfeature",
    "feature-flags",
    "dispatch",
    "expo",
    "react-native"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AppDispatch/openfeature-provider"
  },
  "license": "MIT",
  "peerDependencies": {
    "@openfeature/core": ">=1.0.0"
  },
  "devDependencies": {
    "@openfeature/core": "^1.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
